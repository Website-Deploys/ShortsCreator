# ---------------------------------------------------------------------------
# Project Olympus - Environment configuration template.
#
# Copy this file to `.env` and adjust values for your local environment.
# All variables are prefixed with `OLYMPUS_`. Nested settings use a double
# underscore (`__`) as the delimiter, e.g. OLYMPUS_DATABASE__URL.
#
# NEVER commit a real `.env` file. Secrets belong in a secrets manager in
# staging/production (see the Technology Constitution).
# ---------------------------------------------------------------------------

# Core application
OLYMPUS_ENVIRONMENT=development
OLYMPUS_DEBUG=true
OLYMPUS_LOG_LEVEL=INFO
# Use "console" for human-readable logs in development, "json" in production.
OLYMPUS_LOG_FORMAT=console

# HTTP API
OLYMPUS_API__HOST=0.0.0.0
OLYMPUS_API__PORT=8000
# Comma-separated list of allowed CORS origins (frontend URLs).
OLYMPUS_API__CORS_ORIGINS=http://localhost:3000

# Database (PostgreSQL, async driver)
OLYMPUS_DATABASE__URL=postgresql+asyncpg://olympus:olympus@localhost:5432/olympus
OLYMPUS_DATABASE__POOL_SIZE=5
OLYMPUS_DATABASE__ECHO=false

# Redis (cache + Celery broker/result backend in the MVP)
OLYMPUS_REDIS__URL=redis://localhost:6379/0

# Queue (Celery)
OLYMPUS_QUEUE__BROKER_URL=redis://localhost:6379/1
OLYMPUS_QUEUE__RESULT_BACKEND=redis://localhost:6379/2

# Storage abstraction
# backend = "local" (default, no credentials needed) | "s3"
OLYMPUS_STORAGE__BACKEND=local
OLYMPUS_STORAGE__LOCAL_ROOT=./storage_data
# Only used when backend = "s3"
OLYMPUS_STORAGE__S3_BUCKET=
OLYMPUS_STORAGE__S3_REGION=
OLYMPUS_STORAGE__S3_ENDPOINT_URL=
OLYMPUS_STORAGE__S3_ACCESS_KEY_ID=
OLYMPUS_STORAGE__S3_SECRET_ACCESS_KEY=

# AI service abstraction.
# Use "faster-whisper" for local end-to-end clip generation. "noop" lets the
# API boot without model weights, but no transcript or real clips will be made.
OLYMPUS_AI__TRANSCRIPTION_PROVIDER=faster-whisper

# faster-whisper tuning (only used when TRANSCRIPTION_PROVIDER=faster-whisper)
OLYMPUS_AI__WHISPER_MODEL=tiny
OLYMPUS_AI__WHISPER_DEVICE=cpu
OLYMPUS_AI__WHISPER_COMPUTE_TYPE=int8
OLYMPUS_AI__WHISPER_BEAM_SIZE=1
OLYMPUS_AI__WHISPER_LANGUAGE=
OLYMPUS_AI__WHISPER_DOWNLOAD_ROOT=
OLYMPUS_AI__WHISPER_TIMEOUT_SECONDS=600

# Rendering abstraction
OLYMPUS_RENDERING__BACKEND=ffmpeg
OLYMPUS_RENDERING__FFMPEG_BINARY=ffmpeg
OLYMPUS_RENDERING__FFPROBE_BINARY=ffprobe
OLYMPUS_RENDERING__ASSET_ROOT=./assets

# Copyright / Safety Checker V2. This is a technical risk assessment only;
# it cannot establish fair use, legal approval, Content ID results, or platform approval.
OLYMPUS_COPYRIGHT_SAFETY__ENABLED=true
OLYMPUS_COPYRIGHT_SAFETY__WARN_ONLY=false
OLYMPUS_COPYRIGHT_SAFETY__BLOCK_ON_BLOCKED=true
OLYMPUS_COPYRIGHT_SAFETY__BLOCK_ON_HIGH_RISK=false
OLYMPUS_COPYRIGHT_SAFETY__REQUIRE_RIGHTS_CONFIRMATION_FOR_LINKS=true
OLYMPUS_COPYRIGHT_SAFETY__REQUIRE_MUSIC_LICENSE_VERIFIED=true
OLYMPUS_COPYRIGHT_SAFETY__REQUIRE_SFX_LICENSE_VERIFIED=true
OLYMPUS_COPYRIGHT_SAFETY__REQUIRE_VISUAL_ASSET_LICENSE_VERIFIED=true
OLYMPUS_COPYRIGHT_SAFETY__WARN_ON_UNKNOWN_SOURCE=true
OLYMPUS_COPYRIGHT_SAFETY__WARN_ON_GENERATED_VALIDATION_MUSIC=true
OLYMPUS_COPYRIGHT_SAFETY__REQUIRE_MANUAL_REVIEW_FOR_THIRD_PARTY_LINKS=true
OLYMPUS_COPYRIGHT_SAFETY__MAX_REPORT_TEXT_EXCERPT_CHARS=300

# Title / Description / Hashtag V2. Metadata is deterministic and grounded in
# clip intelligence; these controls cannot enable copied or misleading claims.
OLYMPUS_UPLOAD_METADATA__ENABLED=true
OLYMPUS_UPLOAD_METADATA__GENERATE_YOUTUBE=true
OLYMPUS_UPLOAD_METADATA__GENERATE_INSTAGRAM=true
OLYMPUS_UPLOAD_METADATA__GENERATE_TIKTOK=true
OLYMPUS_UPLOAD_METADATA__MAX_TITLE_LENGTH=70
OLYMPUS_UPLOAD_METADATA__MAX_YOUTUBE_HASHTAGS=8
OLYMPUS_UPLOAD_METADATA__MAX_INSTAGRAM_HASHTAGS=12
OLYMPUS_UPLOAD_METADATA__MAX_TIKTOK_HASHTAGS=8
OLYMPUS_UPLOAD_METADATA__ALLOW_EMOJIS=false
OLYMPUS_UPLOAD_METADATA__ALLOW_CURIOSITY_TITLES=true
OLYMPUS_UPLOAD_METADATA__BLOCK_MISLEADING_CLAIMS=true
OLYMPUS_UPLOAD_METADATA__BLOCK_SPAM_HASHTAGS=true
OLYMPUS_UPLOAD_METADATA__REQUIRE_SAFETY_CHECK=true
OLYMPUS_UPLOAD_METADATA__REQUIRE_MANUAL_REVIEW_WARNING=true
OLYMPUS_UPLOAD_METADATA__GENERATE_AB_VARIANTS=true
OLYMPUS_UPLOAD_METADATA__TITLE_VARIANT_COUNT=5

# Creator Personalization V2 (local and explicit-feedback only)
OLYMPUS_CREATOR_PERSONALIZATION__ENABLED=true
OLYMPUS_CREATOR_PERSONALIZATION__LEARNING_ENABLED_BY_DEFAULT=false
OLYMPUS_CREATOR_PERSONALIZATION__EXPLICIT_FEEDBACK_ONLY=true
OLYMPUS_CREATOR_PERSONALIZATION__ACTIVE_PROFILE_ID=default
OLYMPUS_CREATOR_PERSONALIZATION__STORAGE_DIR=work/personalization

# Local Durable Job Queue / Resume V2 (no Redis/Celery required)
OLYMPUS_DURABLE_JOBS__ENABLED=true
OLYMPUS_DURABLE_JOBS__STORAGE_DIR=work/jobs
OLYMPUS_DURABLE_JOBS__RUN_IN_PROCESS=true
OLYMPUS_DURABLE_JOBS__HEARTBEAT_INTERVAL_SECONDS=10
OLYMPUS_DURABLE_JOBS__STALE_AFTER_SECONDS=120
OLYMPUS_DURABLE_JOBS__MAX_ATTEMPTS=3
OLYMPUS_DURABLE_JOBS__CLEANUP_COMPLETED_AFTER_DAYS=14
OLYMPUS_DURABLE_JOBS__CLEANUP_FAILED_AFTER_DAYS=30
OLYMPUS_DURABLE_JOBS__ALLOW_RESUME_COMPLETED=false
OLYMPUS_DURABLE_JOBS__ALLOW_PARTIAL_RENDER_RESUME=true
OLYMPUS_DURABLE_JOBS__PREVENT_DUPLICATE_PROJECT_JOBS=true
OLYMPUS_DURABLE_JOBS__MAX_LOGS_TAIL_CHARS=8000
OLYMPUS_DURABLE_JOBS__WORKER_POLL_INTERVAL_SECONDS=2
OLYMPUS_CREATOR_PERSONALIZATION__MAX_FEEDBACK_NOTES_CHARS=500
OLYMPUS_CREATOR_PERSONALIZATION__MAX_PROFILES=20
OLYMPUS_CREATOR_PERSONALIZATION__APPLY_TO_PLANNING=true
OLYMPUS_CREATOR_PERSONALIZATION__APPLY_TO_EDITING=true
OLYMPUS_CREATOR_PERSONALIZATION__APPLY_TO_MUSIC=true
OLYMPUS_CREATOR_PERSONALIZATION__APPLY_TO_CAPTIONS=true
OLYMPUS_CREATOR_PERSONALIZATION__APPLY_TO_MOTION=true
OLYMPUS_CREATOR_PERSONALIZATION__APPLY_TO_UPLOAD_METADATA=true
OLYMPUS_CREATOR_PERSONALIZATION__MAX_SCORE_DELTA=0.15
OLYMPUS_CREATOR_PERSONALIZATION__CONSERVATIVE_UNTIL_FEEDBACK_COUNT=5
OLYMPUS_CREATOR_PERSONALIZATION__ALLOW_EXPORT_IMPORT=true

# Video-link ingestion (public YouTube watch, youtu.be, and Shorts URLs only).
# Optional downloader dependency:
# python -m pip install -e ".[video-links]"
OLYMPUS_LINK_INGESTION__ENABLED=true
OLYMPUS_LINK_INGESTION__ALLOWED_PLATFORMS=youtube
OLYMPUS_LINK_INGESTION__MAX_SOURCE_DURATION_MINUTES=120
OLYMPUS_LINK_INGESTION__MAX_SOURCE_FILE_SIZE_MB=4096
OLYMPUS_LINK_INGESTION__MAX_HEIGHT=1440
OLYMPUS_LINK_INGESTION__PREFERRED_CONTAINER=mp4
OLYMPUS_LINK_INGESTION__PREFERRED_VIDEO_CODECS=h264,avc1,vp9,av01
OLYMPUS_LINK_INGESTION__PREFERRED_AUDIO_CODECS=aac,opus,m4a
OLYMPUS_LINK_INGESTION__ALLOW_DIRECT_MEDIA_URLS=false
OLYMPUS_LINK_INGESTION__ALLOW_PLAYLISTS=false
OLYMPUS_LINK_INGESTION__ALLOW_LIVE_STREAMS=false
OLYMPUS_LINK_INGESTION__REQUIRE_USER_RIGHTS_CONFIRMATION=true
OLYMPUS_LINK_INGESTION__DOWNLOAD_TIMEOUT_SECONDS=7200
OLYMPUS_LINK_INGESTION__METADATA_TIMEOUT_SECONDS=60
OLYMPUS_LINK_INGESTION__CLEANUP_PARTIAL_DOWNLOADS=true
OLYMPUS_LINK_INGESTION__REPORT_PROGRESS_INTERVAL_SECONDS=1

# Internet Trend Research V2. The default is an honest evergreen fallback and
# requires no key. A configured web endpoint must return concise JSON search
# summaries; Olympus never fetches result pages or downloads third-party media.
OLYMPUS_TREND_RESEARCH__ENABLED=true
OLYMPUS_TREND_RESEARCH__PROVIDER=evergreen
OLYMPUS_TREND_RESEARCH__ALLOW_OFFICIAL_SOURCE_REFRESH=true
OLYMPUS_TREND_RESEARCH__ALLOW_CONFIGURED_WEB_SEARCH=false
OLYMPUS_TREND_RESEARCH__ALLOW_LIVE_WEB_PROVIDER=false
OLYMPUS_TREND_RESEARCH__CONFIGURED_SEARCH_ENDPOINT=
OLYMPUS_TREND_RESEARCH__CONFIGURED_SEARCH_API_KEY_ENV=
OLYMPUS_TREND_RESEARCH__CONFIGURED_SEARCH_PROVIDER_NAME=custom
OLYMPUS_TREND_RESEARCH__FETCH_CONFIGURED_RESULT_PAGES=false
OLYMPUS_TREND_RESEARCH__WEB_SEARCH_ENDPOINT=
OLYMPUS_TREND_RESEARCH__WEB_SEARCH_API_KEY=
OLYMPUS_TREND_RESEARCH__CACHE_ENABLED=true
OLYMPUS_TREND_RESEARCH__CACHE_DIR=work/trend_cache
OLYMPUS_TREND_RESEARCH__MAX_QUERIES_PER_VIDEO=5
OLYMPUS_TREND_RESEARCH__MAX_SOURCES_PER_SNAPSHOT=12
OLYMPUS_TREND_RESEARCH__GENERAL_TTL_HOURS=168
OLYMPUS_TREND_RESEARCH__NICHE_TTL_HOURS=72
OLYMPUS_TREND_RESEARCH__FAST_TTL_HOURS=24
OLYMPUS_TREND_RESEARCH__STALE_CACHE_ALLOWED_HOURS=336
OLYMPUS_TREND_RESEARCH__LIVE_REFRESH_MIN_INTERVAL_HOURS=12
OLYMPUS_TREND_RESEARCH__FORCE_LIVE_REFRESH=false
OLYMPUS_TREND_RESEARCH__MAX_FETCH_BYTES=250000
OLYMPUS_TREND_RESEARCH__REQUEST_TIMEOUT_SECONDS=15
OLYMPUS_TREND_RESEARCH__MAX_REDIRECTS=3
OLYMPUS_TREND_RESEARCH__USER_AGENT=OlympusTrendResearch/1.0
OLYMPUS_TREND_RESEARCH__SOURCE_ALLOWLIST_ENABLED=true
OLYMPUS_TREND_RESEARCH__ALLOWED_DOMAINS=["youtube.com","support.google.com","blog.youtube","creators.instagram.com","about.instagram.com","newsroom.tiktok.com","ads.tiktok.com","creatoracademy.youtube.com"]
OLYMPUS_TREND_RESEARCH__BLOCKED_DOMAINS=[]
OLYMPUS_TREND_RESEARCH__FALLBACK_TO_EVERGREEN=true
OLYMPUS_TREND_RESEARCH__REQUIRE_SOURCE_ATTRIBUTION=true
OLYMPUS_TREND_RESEARCH__RECENCY_WINDOW_DAYS=30
OLYMPUS_TREND_RESEARCH__LANGUAGE=en
OLYMPUS_TREND_RESEARCH__REGION=

# Music Intelligence V2 (safe local assets only; no music downloading or scraping)
OLYMPUS_MUSIC_INTELLIGENCE__ENABLED=true
OLYMPUS_MUSIC_INTELLIGENCE__REQUIRE_LICENSE_VERIFIED=true
OLYMPUS_MUSIC_INTELLIGENCE__ALLOW_UNKNOWN_LICENSE=false
OLYMPUS_MUSIC_INTELLIGENCE__ALLOW_VOCAL_MUSIC_UNDER_SPEECH=false
OLYMPUS_MUSIC_INTELLIGENCE__DEFAULT_MUSIC_GAIN_DB=-20
OLYMPUS_MUSIC_INTELLIGENCE__MIN_MUSIC_GAIN_DB=-32
OLYMPUS_MUSIC_INTELLIGENCE__MAX_MUSIC_GAIN_DB=-14
OLYMPUS_MUSIC_INTELLIGENCE__ENABLE_DUCKING=true
OLYMPUS_MUSIC_INTELLIGENCE__DUCKING_THRESHOLD_DB=-24
OLYMPUS_MUSIC_INTELLIGENCE__DUCKING_RATIO=6
OLYMPUS_MUSIC_INTELLIGENCE__DUCKING_REDUCTION_DB=6
OLYMPUS_MUSIC_INTELLIGENCE__DUCKING_ATTACK_MS=120
OLYMPUS_MUSIC_INTELLIGENCE__DUCKING_RELEASE_MS=450
OLYMPUS_MUSIC_INTELLIGENCE__FADE_IN_SECONDS=0.35
OLYMPUS_MUSIC_INTELLIGENCE__FADE_OUT_SECONDS=0.8
OLYMPUS_MUSIC_INTELLIGENCE__ENABLE_PAYOFF_SWELL=true
OLYMPUS_MUSIC_INTELLIGENCE__ENABLE_HOOK_MUSIC_EVENT=true
OLYMPUS_MUSIC_INTELLIGENCE__AVOID_MUSIC_FOR_SINGING=true
OLYMPUS_MUSIC_INTELLIGENCE__MAX_TRACK_REUSE_PER_PROJECT=2
OLYMPUS_MUSIC_INTELLIGENCE__VALIDATION_REQUIRED=true
OLYMPUS_MUSIC_INTELLIGENCE__FALLBACK_TO_GENERATED_ASSETS=true

# Multi-Speaker Layout V2 (anonymous temporal tracking only; no face recognition)
OLYMPUS_MULTI_SPEAKER_LAYOUT__ENABLED=true
OLYMPUS_MULTI_SPEAKER_LAYOUT__PREFER_TWO_SPEAKER_STACK=true
OLYMPUS_MULTI_SPEAKER_LAYOUT__ENABLE_ACTIVE_SPEAKER_FOCUS=true
OLYMPUS_MULTI_SPEAKER_LAYOUT__ENABLE_MULTI_FACE_SAFE_FRAME=true
OLYMPUS_MULTI_SPEAKER_LAYOUT__MINIMUM_FACE_CONFIDENCE=0.55
OLYMPUS_MULTI_SPEAKER_LAYOUT__MINIMUM_TRACK_COVERAGE=0.45
OLYMPUS_MULTI_SPEAKER_LAYOUT__MINIMUM_ASSOCIATION_CONFIDENCE=0.60
OLYMPUS_MULTI_SPEAKER_LAYOUT__MINIMUM_SPEAKER_HOLD_SECONDS=1.2
OLYMPUS_MULTI_SPEAKER_LAYOUT__SWITCH_HYSTERESIS_SECONDS=0.45
OLYMPUS_MULTI_SPEAKER_LAYOUT__MISSING_DETECTION_HOLD_SECONDS=0.6
OLYMPUS_MULTI_SPEAKER_LAYOUT__INTERPOLATION_MAX_GAP_SECONDS=1.0
OLYMPUS_MULTI_SPEAKER_LAYOUT__MAX_CROP_MOVEMENT_PER_SECOND=0.22
OLYMPUS_MULTI_SPEAKER_LAYOUT__MAX_ZOOM_CHANGE_PER_SECOND=0.18
OLYMPUS_MULTI_SPEAKER_LAYOUT__MAXIMUM_RENDER_SWITCHES_PER_MINUTE=24
OLYMPUS_MULTI_SPEAKER_LAYOUT__PRESERVE_NATURAL_TWO_FACE_FRAME=true
OLYMPUS_MULTI_SPEAKER_LAYOUT__FALLBACK_TO_CENTER_CROP=true
OLYMPUS_MULTI_SPEAKER_LAYOUT__VALIDATION_REQUIRED=true

# Captions / Typography V2 (system-font families only; no font files are bundled)
OLYMPUS_CAPTION_INTELLIGENCE__ENABLED=true
OLYMPUS_CAPTION_INTELLIGENCE__DEFAULT_STYLE=default_clean
OLYMPUS_CAPTION_INTELLIGENCE__PREFER_WORD_LEVEL=true
OLYMPUS_CAPTION_INTELLIGENCE__ALLOW_ESTIMATED_WORD_TIMING=true
OLYMPUS_CAPTION_INTELLIGENCE__MAX_WORDS_PER_LINE=7
OLYMPUS_CAPTION_INTELLIGENCE__MAX_LINES=2
OLYMPUS_CAPTION_INTELLIGENCE__MIN_DISPLAY_TIME_SECONDS=0.35
OLYMPUS_CAPTION_INTELLIGENCE__MAX_DISPLAY_TIME_SECONDS=3.2
OLYMPUS_CAPTION_INTELLIGENCE__ENABLE_HOOK_TREATMENT=true
OLYMPUS_CAPTION_INTELLIGENCE__ENABLE_KEYWORD_EMPHASIS=true
OLYMPUS_CAPTION_INTELLIGENCE__ENABLE_SPEAKER_AWARE_CAPTIONS=true
OLYMPUS_CAPTION_INTELLIGENCE__ENABLE_FACE_AVOIDANCE=true
OLYMPUS_CAPTION_INTELLIGENCE__ENABLE_SAFE_ZONE_VALIDATION=true
OLYMPUS_CAPTION_INTELLIGENCE__ENABLE_CAPTION_RENDER_VALIDATION=true
OLYMPUS_CAPTION_INTELLIGENCE__ALLOW_EMOJI=false
OLYMPUS_CAPTION_INTELLIGENCE__REQUIRE_READABILITY_VALIDATION=true
OLYMPUS_CAPTION_FONTS__PRIMARY=Arial
OLYMPUS_CAPTION_FONTS__FALLBACK=["Arial","Segoe UI","Verdana"]
OLYMPUS_CAPTION_FONTS__ALLOW_CUSTOM_FONT_PATHS=false

# Motion Graphics / Effects V2 (bounded FFmpeg-native effects; no flash or speed ramps)
OLYMPUS_MOTION_GRAPHICS__ENABLED=true
OLYMPUS_MOTION_GRAPHICS__DEFAULT_STYLE=default_clean
OLYMPUS_MOTION_GRAPHICS__MAX_MAJOR_EFFECTS_UNDER_15S=3
OLYMPUS_MOTION_GRAPHICS__MAX_MAJOR_EFFECTS_UNDER_30S=5
OLYMPUS_MOTION_GRAPHICS__ENABLE_HOOK_PUNCH_IN=true
OLYMPUS_MOTION_GRAPHICS__ENABLE_PATTERN_INTERRUPTS=true
OLYMPUS_MOTION_GRAPHICS__ENABLE_PAYOFF_HOLD=true
OLYMPUS_MOTION_GRAPHICS__ENABLE_SUBTLE_PUSH_IN=true
OLYMPUS_MOTION_GRAPHICS__ENABLE_REACTION_ZOOM=true
OLYMPUS_MOTION_GRAPHICS__ENABLE_SPEED_RAMPS=false
OLYMPUS_MOTION_GRAPHICS__ENABLE_SAFE_FLASH=false
OLYMPUS_MOTION_GRAPHICS__ENABLE_MICRO_SHAKE=true
OLYMPUS_MOTION_GRAPHICS__ENABLE_BACKGROUND_BLUR=true
OLYMPUS_MOTION_GRAPHICS__MAX_ZOOM_SCALE=1.18
OLYMPUS_MOTION_GRAPHICS__MAX_MICRO_SHAKE_SECONDS=0.35
OLYMPUS_MOTION_GRAPHICS__REQUIRE_CAPTION_SAFETY=true
OLYMPUS_MOTION_GRAPHICS__REQUIRE_FACE_SAFETY=true
OLYMPUS_MOTION_GRAPHICS__REQUIRE_LAYOUT_SAFETY=true
OLYMPUS_MOTION_GRAPHICS__REQUIRE_RENDER_VALIDATION=true

# BOBA Core Brain V1 (offline and advisory; no autonomous scouting or global learning)
OLYMPUS_BOBA__ENABLED=true
OLYMPUS_BOBA__MODE=advise
OLYMPUS_BOBA__STORAGE_DIR=work/boba
OLYMPUS_BOBA__MAX_EXCERPT_CHARS=300
OLYMPUS_BOBA__MAX_DECISIONS_PER_PROJECT=500
OLYMPUS_BOBA__ENABLE_PROJECT_MEMORY=true
OLYMPUS_BOBA__ENABLE_CANDIDATE_RANKING=true
OLYMPUS_BOBA__ENABLE_EDITORIAL_POLICY=true
OLYMPUS_BOBA__ENABLE_FRONTEND_DISPLAY=true
OLYMPUS_BOBA__ENABLE_GLOBAL_LEARNING=false
OLYMPUS_BOBA__ENABLE_AUTONOMOUS_SCOUT=false
OLYMPUS_BOBA__REQUIRE_USER_APPROVAL_FOR_SOURCES=true
OLYMPUS_BOBA__EXPLAIN_EVERY_DECISION=true
